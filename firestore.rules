rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Job documents are written ONLY by the Admin SDK inside Cloud Functions,
    // which bypasses these rules. The client just subscribes to a job by its
    // ?job=<id> URL, so it needs read access and nothing more.
    match /jobs/{jobId} {
      // Public read for now — there is no login yet. When accounts land,
      // tighten this to per-user reads, e.g.:
      //   allow read: if request.auth != null
      //               && request.auth.uid == resource.data.ownerId;
      allow read: if true;

      // No client writes, ever. Only the Functions Admin SDK writes jobs.
      allow write: if false;
    }

    // Everything else is locked down by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
